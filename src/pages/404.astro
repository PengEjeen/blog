---
import { Compass, Home as HomeIcon } from 'lucide-react';
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<Layout title="404 — 페이지 없음" noIndex>
  <div class="notfound">
    <Compass size={56} className="notfound-icon" strokeWidth={1.5} />
    <h1 class="notfound-code">404</h1>
    <p class="notfound-msg">길을 잃으셨네요. 이 경로엔 아무 것도 없어요.</p>
    <a href={`${baseUrl}/`} class="notfound-cta">
      <HomeIcon size={15} /> 홈으로
    </a>
  </div>
</Layout>
