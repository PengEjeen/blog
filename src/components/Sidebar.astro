---
import {
  Server,
  MonitorPlay,
  Activity,
  Cpu,
  Database,
  CloudRain,
  Brain,
  Folder,
  Plane,
  Wrench,
  Clock,
  Hash,
} from 'lucide-react';
import { getPostsIndex, humanize, buildCatHref, buildPostHref } from '../utils/posts';
import SidebarSearch from './SidebarSearch.tsx';

const CATEGORY_ICONS: Record<string, any> = {
  CS: Cpu,
  BE: Server,
  FE: MonitorPlay,
  ML: Brain,
  AI: Brain,
  MLAI: Brain,
  Database: Database,
  DevOps: Activity,
  Cloud: CloudRain,
  Tools: Wrench,
  Travel: Plane,
  기타: Folder,
};

const CATEGORY_LABELS: Record<string, string> = {
  BE: 'Backend',
  FE: 'Frontend',
  ML: 'Machine Learning',
  AI: 'AI',
  MLAI: 'ML / AI',
};

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const { categories, posts, total } = await getPostsIndex();
const recents = posts.slice(0, 5);

// Active category derived at build time from current URL.
const pathname = decodeURIComponent(Astro.url.pathname);
const stripped = pathname.startsWith(baseUrl) ? pathname.slice(baseUrl.length) : pathname;
const activeCategory = stripped.startsWith('/category/') ? stripped.split('/')[2] : null;

// Search index (lean version for the client island).
const searchIndex = posts.map((p) => ({
  cat: p.cat,
  sub: p.sub,
  slug: p.slug,
  title: p.title,
  href: `${baseUrl}${buildPostHref(p)}`,
  searchHay: p.searchHay,
}));
---

<button
  type="button"
  class="sidebar-backdrop"
  aria-label="사이드바 닫기"
  data-sidebar-close
></button>

<aside id="primary-sidebar" class="sidebar" aria-label="사이트 내비게이션">
  <SidebarSearch index={searchIndex} client:load />

  <div class="sidebar-section">
    <div class="sidebar-stats">
      <div class="sidebar-stat">
        <span class="sidebar-stat-value">{total}</span>
        <span class="sidebar-stat-label">posts</span>
      </div>
      <div class="sidebar-stat">
        <span class="sidebar-stat-value">{categories.length}</span>
        <span class="sidebar-stat-label">categories</span>
      </div>
    </div>
  </div>

  <div class="sidebar-section">
    <h3 class="sidebar-heading">
      <Hash size={13} /> Categories
    </h3>
    <ul class="sidebar-list">
      {
        categories.map((cat) => {
          const Icon = CATEGORY_ICONS[cat.slug] || Folder;
          const label = CATEGORY_LABELS[cat.slug] || humanize(cat.slug);
          const isActive = activeCategory === cat.slug;
          return (
            <li>
              <a
                href={`${baseUrl}${buildCatHref(cat.slug)}`}
                class={`sidebar-link${isActive ? ' sidebar-link--active' : ''}`}
              >
                <span class="sidebar-link-icon"><Icon size={15} strokeWidth={1.6} /></span>
                <span class="sidebar-link-label">{label}</span>
                <span class="sidebar-link-count">{cat.count}</span>
              </a>
            </li>
          );
        })
      }
    </ul>
  </div>

  {
    recents.length > 0 && (
      <div class="sidebar-section">
        <h3 class="sidebar-heading">
          <Clock size={13} /> Recent Posts
        </h3>
        <ul class="sidebar-recent-list">
          {recents.map((p) => (
            <li>
              <a
                href={`${baseUrl}${buildPostHref(p)}`}
                class="sidebar-recent-item"
              >
                <span class="sidebar-recent-title">{p.title}</span>
                <span class="sidebar-recent-meta">
                  {humanize(p.cat)} · {p.dateLabel}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    )
  }
</aside>

<style is:global>
  /* Map body.sidebar-open → original .sidebar--open behavior. */
  @media (max-width: 1080px) {
    body.sidebar-open #primary-sidebar { transform: translateX(0); }
    body.sidebar-open .sidebar-backdrop { display: block; }
  }
</style>
